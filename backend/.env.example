PROJECT_NAME=Havilah EdTech API
VERSION=1.0.0
API_V1_STR=/api/v1

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/havilah
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=havilah_edtech_content

SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASSWORD=your-password
EMAILS_FROM_EMAIL=havilah@example.com

OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini
AI_SERVICE=openai
CONTENT_PIPELINE_COLLECTION=content_pipelines

OCR_ENABLED=true
OCR_LANGUAGE=eng

FILE_STORAGE_BACKEND=local
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=havilah-edtech
MINIO_SECURE=false
UPLOAD_STORAGE_DIR=uploaded_files
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,application/pdf
